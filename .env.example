BOT_TOKEN=insert_telegram_bot_token_here
DATABASE_URL=postgresql://velvet:velvet_password@localhost:5432/velvet
ALLOWED_USERNAMES=va_stellmaria
ALLOWED_USER_IDS=
LOG_CHAT_ID=-5367533184
ANALYTICS_CHANNEL_IDS=-1003802812639
PUBLICATION_TIMEZONE=Europe/Berlin
BACKUP_DIR=backups
PG_DUMP_PATH=pg_dump
PG_RESTORE_PATH=pg_restore

# Глубокий смысловой анализ изображений. По умолчанию выключен, поэтому бот
# запускается и работает без установленного ИИ.
# Для локальной машины с 4 ГБ VRAM рекомендуется vision-модель gemma3:4b.
# Перед включением скачайте её командой: ollama pull gemma3:4b
AI_VISION_ENABLED=false
AI_VISION_PROVIDER=ollama
AI_VISION_BASE_URL=http://127.0.0.1:11434
AI_VISION_MODEL=gemma3:4b
AI_VISION_API_KEY=
AI_VISION_TIMEOUT_SECONDS=180
AI_VISION_MAX_ATTEMPTS=3

# Внешний Supervisor запускает main.py, собирает логи, перезапускает бот и
# выполняет безопасные обновления. Сгенерируйте отдельный случайный токен.
SUPERVISOR_ENABLED=false
SUPERVISOR_TOKEN=replace_with_random_token_at_least_24_characters
SUPERVISOR_HOST=127.0.0.1
SUPERVISOR_PORT=8765
SUPERVISOR_BASE_URL=http://127.0.0.1:8765
SUPERVISOR_ALLOW_REMOTE=false
SUPERVISOR_PROJECT_DIR=.
SUPERVISOR_PYTHON=.venv314\Scripts\python.exe
SUPERVISOR_BOT_COMMAND=".venv314\Scripts\python.exe" main.py
SUPERVISOR_TEST_COMMAND=".venv314\Scripts\python.exe" -m unittest discover -s tests -v
SUPERVISOR_AUTO_RESTART=true
SUPERVISOR_MAX_RESTARTS=3
SUPERVISOR_RESTART_WINDOW_SECONDS=600
SUPERVISOR_STARTUP_GRACE_SECONDS=12
SUPERVISOR_COMMAND_TIMEOUT_SECONDS=900
SUPERVISOR_CLIENT_TIMEOUT_SECONDS=20
SUPERVISOR_UPDATE_REMOTE=origin
SUPERVISOR_UPDATE_BRANCH=main
SUPERVISOR_LOG_DIR=logs
SUPERVISOR_RUNTIME_DIR=runtime/supervisor
SUPERVISOR_NOTIFICATION_CHAT_ID=
SUPERVISOR_NOTIFICATION_BOT_TOKEN=
# Необязательно. По умолчанию критические уведомления дублируются всем ID из
# ALLOWED_USER_IDS. Можно задать отдельный список Telegram ID через запятую.
SUPERVISOR_NOTIFICATION_OWNER_IDS=
SUPERVISOR_MAX_LOG_LINES=2000

# Необязательное подключение Codex CLI. Сначала выполните codex login на том же
# компьютере. Каждая задача работает в отдельном Git worktree.
CODEX_ENABLED=false
CODEX_COMMAND=codex exec --json --sandbox workspace-write -
CODEX_TIMEOUT_SECONDS=1800
CODEX_WORKTREE_DIR=runtime/supervisor/codex-worktrees
CODEX_PUSH_REMOTE=origin
